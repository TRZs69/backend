{
  "name": "backend",
  "version": "1.0.0",
  "description": "Gamified Elearning App",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch --env-file=.env ./src/index.js",
    "start": "node ./src/index.js",
    "test": "jest --verbose",
    "test:load": "npx -y artillery@latest run tests/load/eloLoadTest.yml",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "render-build": "npm install && npm run db:generate",
    "fix:badge-urls": "node scripts/fix_badge_image_urls.js",
    "sync:student-only-elo": "node scripts/sync_student_only_elo.js",
    "chat:backfill-chapter:dry": "node scripts/backfill_chat_session_chapter_ids.js",
    "chat:backfill-chapter": "node scripts/backfill_chat_session_chapter_ids.js --apply"
  },
  "author": "archico",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/extension-accelerate": "^3.0.1",
    "@supabase/supabase-js": "^2.49.1",
    "axios": "^1.7.9",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "google-auth-library": "^9.14.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql": "^2.18.1",
    "mysql2": "^3.22.3",
    "node-cache": "^5.1.2",
    "path": "^0.12.7",
    "pdf-parse": "^2.4.5",
    "pg": "^8.13.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@prisma/client": "^6.4.1",
    "@types/jsonwebtoken": "^9.0.8",
    "jest": "^30.2.0",
    "nodemon": "^3.1.9",
    "prisma": "^6.4.1"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
