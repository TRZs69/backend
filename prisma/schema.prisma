// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int           @id @default(autoincrement())
  username          String        @unique
  password          String    
  name              String
  role              Role
  studentId         String?       // Data khusus student
  points            Int? @default(0)
  elo               Int? @default(750)
  totalCourses      Int? @default(0)
  badges            Int? @default(0)
  instructorId      String?       // Data khusus instructor
  instructorCourses Int?
  image             String?       @default("")
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relasi
  enrolledCourses   UserCourse[]
  chapterProgress   UserChapter[]
  assessmentAttempts AssessmentAttempt[]
  userBadges        UserBadge[]
  userTrades        UserTrade[]
  sessions          UserSession[]
  questionnaires    EvaluationQuestionnaire[]

  @@map("users")
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

model Course {
  id          Int           @id @default(autoincrement())
  code        String
  name        String
  description String        @db.Text
  image       String        @default("")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relasi
  chapters    Chapter[]
  enrollments UserCourse[]
  badges      Badge[]

  @@map("courses")
}

model UserCourse {
  id              Int       @id @default(autoincrement())
  userId          Int
  courseId        Int
  elo             Int       @default(750)
  progress        Int       @default(0)
  currentChapter  Int       @default(1)
  isCompleted     Boolean   @default(false)
  timeStarted     DateTime  @default(now()) 
  timeFinished    DateTime  @default(now())
  enrolledAt      DateTime  @default(now())
  
  // Relasi
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course        Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("user_courses")
}

model Chapter {
  id              Int       @id @default(autoincrement())
  name            String
  description     String
  level           Int
  courseId        Int
  isCheckpoint    Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relasi
  course          Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  materials       Material[]
  assessments     Assessment[]
  assessmentAttempts AssessmentAttempt[]
  assignments     Assignment[]
  userProgress    UserChapter[]
  badges          Badge[]

  @@index([courseId])
  @@map("chapters")
}

model Material {
  id          Int       @id @default(autoincrement())
  chapterId   Int
  name        String
  content     String    @db.LongText
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relasi
  chapter     Chapter   @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
  @@map("materials")
}

model Assessment {
  id            Int       @id @default(autoincrement())
  chapterId     Int
  instruction   String    @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relasi
  chapter       Chapter   @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  questions     Question[]
  attempts      AssessmentAttempt[]

  @@index([chapterId])
  @@map("assessments")
}

model Question {
  id              Int        @id @default(autoincrement())
  assessmentId    Int
  question        String     @db.Text
  type            String
  options         Json?
  answer          String?    @db.Text
  correctedAnswer String?    @db.Text
  elo             Int        @default(1200)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  assessment      Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  attemptSnapshots AssessmentAttemptQuestion[] @relation("AttemptSourceQuestion")

  @@index([assessmentId])
  @@map("questions")
}

model AssessmentAttempt {
  id            Int                     @id @default(autoincrement())
  userId        Int
  chapterId     Int
  assessmentId  Int?
  status        AssessmentAttemptStatus @default(IN_PROGRESS)
  source        AssessmentAttemptSource @default(GENERATED)
  instruction   String                  @db.Text
  poolSize      Int                     @default(12)
  objectiveTarget Int                   @default(5)
  totalTarget   Int                     @default(6)
  currentUserElo Int                    @default(750)
  courseEloStart Int                    @default(750)
  courseEloEnd   Int                    @default(750)
  rawEloDelta   Float                   @default(0)
  objectiveAnswered Int                 @default(0)
  objectiveCorrect Int                  @default(0)
  grade         Int?
  pointsEarned  Int?
  correctAnswers Int?
  totalQuestions Int?
  newDifficulty Difficulty?
  aiFeedback    String?                 @db.Text
  submittedAt   DateTime?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter       Chapter                 @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  assessment    Assessment?             @relation(fields: [assessmentId], references: [id], onDelete: SetNull)
  questions     AssessmentAttemptQuestion[]

  @@index([userId])
  @@index([chapterId])
  @@index([assessmentId])
  @@index([status])
  @@index([userId, chapterId, status])
  @@map("assessment_attempts")
}

model AssessmentAttemptQuestion {
  id              Int               @id @default(autoincrement())
  attemptId       Int
  sourceQuestionId Int?
  question        String            @db.Text
  type            String
  options         Json?
  answer          String?           @db.Text
  correctedAnswer String?           @db.Text
  elo             Int               @default(1200)
  order           Int
  servedOrder     Int?
  submittedAnswer String?           @db.Text
  isCorrect       Boolean?
  score           Int?
  answeredAt      DateTime?
  userEloDeltaRaw Float?
  questionEloDeltaRaw Float?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  attempt         AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  sourceQuestion  Question?         @relation("AttemptSourceQuestion", fields: [sourceQuestionId], references: [id], onDelete: SetNull)

  @@index([attemptId])
  @@index([sourceQuestionId])
  @@index([attemptId, order])
  @@index([attemptId, servedOrder])
  @@index([attemptId, answeredAt])
  @@map("assessment_attempt_questions")
}

enum AssessmentAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  ABANDONED
}

enum AssessmentAttemptSource {
  GENERATED
  FALLBACK_BANK
}

model Assignment {
  id            Int       @id @default(autoincrement())
  chapterId     Int
  instruction   String    @db.LongText
  fileUrl       String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relasi
  chapter       Chapter   @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
  @@map("assignments")
}

enum QuestType {
  MC
  TF
}

model UserChapter {
  id              Int       @id @default(autoincrement())
  userId          Int
  chapterId       Int
  isStarted       Boolean   @default(false)
  isCompleted     Boolean   @default(false)
  materialDone    Boolean   @default(false)
  assessmentDone  Boolean   @default(false)
  assignmentDone  Boolean   @default(false)
  assessmentAnswer Json? 
  assessmentGrade Int       @default(0)
  assessmentEloDelta Int    @default(0)
  assessmentPointsEarned Int @default(0)
  submission      String?
  timeStarted     DateTime  @default(now()) 
  timeFinished    DateTime  @default(now())
  assignmentScore     Int     @default(0)
  assignmentFeedback  String  @default("")
  currentDifficulty Difficulty @default(BEGINNER)
  correctStreak     Int        @default(0)
  wrongStreak       Int        @default(0)
  lastAiFeedback    String?    @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relasi
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter         Chapter   @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([chapterId])
  @@map("user_chapters")
}

model Badge {
  id        Int      @id @default(autoincrement())
  name      String
  type      BadgeType
  image     String?
  courseId  Int
  chapterId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relasi
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  userBadges UserBadge[]

  @@unique([courseId, chapterId, type])
  @@index([courseId])
  @@index([chapterId])
  @@map("badges")
}

enum BadgeType {
  BEGINNER
  INTERMEDIATE
  ADVANCE
}

model UserBadge {
  id        Int      @id @default(autoincrement())
  userId    Int
  badgeId   Int
  isPurchased Boolean @default(false)
  awardedAt DateTime @default(now())

  // Relasi
  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([badgeId])
  @@map("user_badges")
}

model Trade {
  id                  Int         @id @default(autoincrement())
  title               String
  image               String
  description         String
  requiredBadgeType   BadgeType
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  userTrades UserTrade[]

  @@map("trades")
}

model UserTrade {
  id                  Int         @id @default(autoincrement())
  userId              Int
  tradeId             Int
  purchasedAt         DateTime @default(now())

  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  trade     Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tradeId])
  @@map("user_trades")
}

enum Difficulty {
  BEGINNER
  BASIC_UNDERSTANDING
  DEVELOPING_LEARNER
  INTERMEDIATE
  PROFICIENT
  ADVANCED
  MASTERY
}

model UserSession {
  id            Int       @id @default(autoincrement())
  userId        Int
  loginAt       DateTime  @default(now())
  lastActiveAt  DateTime  @default(now())
  logoutAt      DateTime?
  durationSec   Int?

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([loginAt])
  @@map("user_sessions")
}

model EvaluationQuestionnaire {
  id              Int      @id @default(autoincrement())
  userId          Int
  submittedAt     DateTime @default(now())

  // SDT — Motivasi (Leroux et al., 2024)
  q1Autonomy      Int      // "Saya merasa memiliki kendali atas cara saya belajar"
  q2Competence1   Int      // "Tantangan soal terasa sesuai dengan kemampuan saya"
  q3Competence2   Int      // "Saya merasa berkembang setelah menggunakan LeveLearn"
  q4Relatedness   Int      // "Berinteraksi dengan Levely membuat saya lebih terhubung dengan materi"

  // Engagement (Albakri et al., 2024)
  q5Behavioral    Int      // "Saya aktif menyelesaikan materi dan soal di LeveLearn"
  q6Cognitive     Int      // "Saya berpikir lebih dalam tentang materi saat menggunakan LeveLearn"
  q7Emotional     Int      // "Saya menikmati pengalaman belajar di LeveLearn"

  // Global
  q8Overall       Int      // "Chatbot AI dan gamifikasi adaptif membantu saya belajar lebih baik"

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([submittedAt])
  @@map("evaluation_questionnaires")
}
