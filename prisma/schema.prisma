generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int                       @id @default(autoincrement())
  username           String                    @unique
  password           String
  name               String
  role               Role
  studentId          String?
  points             Int?                      @default(0)
  totalCourses       Int?                      @default(0)
  badges             Int?                      @default(0)
  instructorId       String?
  instructorCourses  Int?
  image              String?                   @default("")
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  elo                Int?                      @default(750)
  assessmentAttempts AssessmentAttempt[]
  chatbot_ratings    chatbot_ratings[]
  questionnaires     EvaluationQuestionnaire[]
  userBadges         UserBadge[]
  chapterProgress    UserChapter[]
  enrolledCourses    UserCourse[]
  sessions           UserSession[]
  userTrades         UserTrade[]

  @@map("users")
}

model Course {
  id          Int          @id @default(autoincrement())
  code        String
  name        String
  description String       @db.Text
  image       String       @default("")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  badges      Badge[]
  chapters    Chapter[]
  enrollments UserCourse[]

  @@map("courses")
}

model UserCourse {
  id             Int      @id @default(autoincrement())
  userId         Int
  courseId       Int
  progress       Int      @default(0)
  currentChapter Int      @default(1)
  isCompleted    Boolean  @default(false)
  timeStarted    DateTime @default(now())
  timeFinished   DateTime @default(now())
  enrolledAt     DateTime @default(now())
  elo            Int      @default(750)
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("user_courses")
}

model Chapter {
  id                 Int                 @id @default(autoincrement())
  name               String
  description        String
  level              Int
  courseId           Int
  isCheckpoint       Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  assessmentAttempts AssessmentAttempt[]
  assessments        Assessment[]
  assignments        Assignment[]
  badges             Badge[]
  course             Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  materials          Material[]
  userProgress       UserChapter[]

  @@index([courseId])
  @@map("chapters")
}

model Material {
  id        Int      @id @default(autoincrement())
  chapterId Int
  name      String
  content   String   @db.LongText
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
  @@map("materials")
}

model Assessment {
  id          Int                 @id @default(autoincrement())
  chapterId   Int
  instruction String              @db.Text
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  attempts    AssessmentAttempt[]
  chapter     Chapter             @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  questions   Question[]

  @@index([chapterId])
  @@map("assessments")
}

model Question {
  id               Int                         @id @default(autoincrement())
  assessmentId     Int
  question         String                      @db.Text
  type             String
  options          Json?
  answer           String?                     @db.Text
  correctedAnswer  String?                     @db.Text
  elo              Int                         @default(1200)
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  attemptSnapshots AssessmentAttemptQuestion[] @relation("AttemptSourceQuestion")
  assessment       Assessment                  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@map("questions")
}

model AssessmentAttempt {
  id                Int                         @id @default(autoincrement())
  userId            Int
  chapterId         Int
  assessmentId      Int?
  status            AssessmentAttemptStatus     @default(IN_PROGRESS)
  source            AssessmentAttemptSource     @default(GENERATED)
  instruction       String                      @db.Text
  grade             Int?
  pointsEarned      Int?
  correctAnswers    Int?
  totalQuestions    Int?
  newDifficulty     Difficulty?
  aiFeedback        String?                     @db.Text
  submittedAt       DateTime?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  poolSize          Int                         @default(12)
  objectiveTarget   Int                         @default(5)
  totalTarget       Int                         @default(6)
  currentUserElo    Int                         @default(750)
  rawEloDelta       Float                       @default(0)
  objectiveAnswered Int                         @default(0)
  objectiveCorrect  Int                         @default(0)
  courseEloStart    Int                         @default(750)
  courseEloEnd      Int                         @default(750)
  questions         AssessmentAttemptQuestion[]
  assessment        Assessment?                 @relation(fields: [assessmentId], references: [id])
  chapter           Chapter                     @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  user              User                        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([chapterId])
  @@index([assessmentId])
  @@index([status])
  @@index([userId, chapterId, status])
  @@map("assessment_attempts")
}

model AssessmentAttemptQuestion {
  id                  Int               @id @default(autoincrement())
  attemptId           Int
  sourceQuestionId    Int?
  question            String            @db.Text
  type                String
  options             Json?
  answer              String?           @db.Text
  correctedAnswer     String?           @db.Text
  elo                 Int               @default(1200)
  order               Int
  submittedAnswer     String?           @db.Text
  isCorrect           Boolean?
  score               Int?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  servedOrder         Int?
  answeredAt          DateTime?
  userEloDeltaRaw     Float?
  questionEloDeltaRaw Float?
  attempt             AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  sourceQuestion      Question?         @relation("AttemptSourceQuestion", fields: [sourceQuestionId], references: [id])

  @@index([attemptId])
  @@index([sourceQuestionId])
  @@index([attemptId, order])
  @@index([attemptId, servedOrder])
  @@index([attemptId, answeredAt])
  @@map("assessment_attempt_questions")
}

model Assignment {
  id          Int      @id @default(autoincrement())
  chapterId   Int
  instruction String   @db.LongText
  fileUrl     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  chapter     Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
  @@map("assignments")
}

model UserChapter {
  id                     Int        @id @default(autoincrement())
  userId                 Int
  chapterId              Int
  isStarted              Boolean    @default(false)
  isCompleted            Boolean    @default(false)
  materialDone           Boolean    @default(false)
  assessmentDone         Boolean    @default(false)
  assignmentDone         Boolean    @default(false)
  assessmentAnswer       Json?
  assessmentGrade        Int        @default(0)
  submission             String?
  timeStarted            DateTime   @default(now())
  timeFinished           DateTime   @default(now())
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
  assignmentFeedback     String     @default("")
  assignmentScore        Int        @default(0)
  correctStreak          Int        @default(0)
  currentDifficulty      Difficulty @default(BEGINNER)
  lastAiFeedback         String?    @db.Text
  wrongStreak            Int        @default(0)
  assessmentEloDelta     Int        @default(0)
  assessmentPointsEarned Int        @default(0)
  chapter                Chapter    @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  user                   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([chapterId])
  @@map("user_chapters")
}

model Badge {
  id         Int         @id @default(autoincrement())
  name       String
  type       BadgeType
  image      String?
  courseId   Int
  chapterId  Int
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  chapter    Chapter     @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  course     Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userBadges UserBadge[]

  @@unique([courseId, chapterId, type])
  @@index([courseId])
  @@index([chapterId])
  @@map("badges")
}

model UserBadge {
  id          Int      @id @default(autoincrement())
  userId      Int
  badgeId     Int
  isPurchased Boolean  @default(false)
  awardedAt   DateTime @default(now())
  badge       Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([badgeId])
  @@map("user_badges")
}

model Trade {
  id                Int         @id @default(autoincrement())
  title             String
  image             String
  description       String
  requiredBadgeType BadgeType
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  userTrades        UserTrade[]

  @@map("trades")
}

model UserTrade {
  id          Int      @id @default(autoincrement())
  userId      Int
  tradeId     Int
  purchasedAt DateTime @default(now())
  trade       Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tradeId])
  @@map("user_trades")
}

model UserSession {
  id           Int       @id @default(autoincrement())
  userId       Int
  loginAt      DateTime  @default(now())
  lastActiveAt DateTime  @default(now())
  logoutAt     DateTime?
  durationSec  Int?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([loginAt])
  @@map("user_sessions")
}

model EvaluationQuestionnaire {
  id            Int      @id @default(autoincrement())
  userId        Int
  submittedAt   DateTime @default(now())
  q1Autonomy    Int
  q2Competence1 Int
  q3Competence2 Int
  q4Relatedness Int
  q5Behavioral  Int
  q6Cognitive   Int
  q7Emotional   Int
  q8Overall     Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([submittedAt])
  @@map("evaluation_questionnaires")
}

model chatbot_ratings {
  id          Int      @id @default(autoincrement())
  userId      Int
  userRequest String   @db.Text
  botResponse String   @db.Text
  rating      Int
  createdAt   DateTime @default(now())
  users       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum AssessmentAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  ABANDONED
}

enum AssessmentAttemptSource {
  GENERATED
  FALLBACK_BANK
}

enum BadgeType {
  BEGINNER
  INTERMEDIATE
  ADVANCE
}

enum Difficulty {
  BEGINNER
  BASIC_UNDERSTANDING
  DEVELOPING_LEARNER
  INTERMEDIATE
  PROFICIENT
  ADVANCED
  MASTERY
}
