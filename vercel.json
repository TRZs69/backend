{
    "regions": ["sin1"],
    "version": 2,
    "functions": {
        "src/index.js": {
            "runtime": "@vercel/node@5.3.24",
            "maxDuration": 30
        }
    },
    "crons": [
        {
            "path": "/api/evaluation/sync/google-sheets/cron",
            "schedule": "0 17 * * *"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/src/index.js"
        }
    ]
}